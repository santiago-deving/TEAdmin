<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TEAdm - Painel Administrativo</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/painel-admin.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="overlay" id="overlay"></div>

    <!-- BARRA DE ACESSIBILIDADE -->
    <div class="barra-acessibilidade" role="toolbar" aria-label="Ferramentas de acessibilidade">
        <span>Acessibilidade:</span>
        <button class="btn-acess" onclick="diminuirFonte()" aria-label="Diminuir fonte">A-</button>
        <button class="btn-acess" onclick="aumentarFonte()" aria-label="Aumentar fonte">A+</button>
        <button class="btn-acess" id="btn-contraste" onclick="alternarContraste()" aria-label="Alternar alto contraste">◑ Contraste</button>
        <button class="btn-acess" id="btn-voz" onclick="alternarVoz()" aria-label="Ativar leitura de tela">🔊 Leitura de tela</button>
        <button class="btn-acess" onclick="abrirLibras()" aria-label="Abrir intérprete de Libras">🤟 Libras</button>
    </div>

    <!-- HEADER -->
    <header class="header">

        <div class="menu_btn" id="menu_btn">
            <i class="bi bi-list"></i>
        </div>
        
        <div class="sidebar" id="sidebar">
            <div class="closeBtn" id="closeBtn">
                <i class="bi bi-x"></i>
            </div>
            <nav>
                <ul>
                    <li><a href="/">Inicio</a></i>
                    <li><a href="/painel_pais">Painel</a></i>
                    <li><a href="/calendario">Calendario</a></i>
                    <li><a href="#">Dados</a></i>
                </ul>
            </nav>
        </div>

        <div class="header-logo">
            <h1><span class="te">TE</span><span class="adm">Adm</span></h1>
        </div>
        <div class="header-info">
            <span>⚙️ Admin: <span id="nome-admin">...</span></span>
            <a href="/pages/login.html" class="btn-sair">Sair</a>
        </div>
    </header>

    <main class="painel-container">

        <!-- BOAS VINDAS -->
        <div class="boas-vindas">
            <h2>⚙️ Painel Administrativo — <span id="nome-boas-vindas">...</span></h2>
            <p>Gerencie terapeutas, pacientes e agendas da clínica</p>
        </div>

        <!-- CARDS RESUMO -->
        <section class="resumo-grid">
            <div class="resumo-card">
                <div class="resumo-icon">👨‍👩‍👧</div>
                <div class="resumo-info">
                    <span id="total-pacientes" class="resumo-numero">--</span>
                    <span class="resumo-label">Pacientes Ativos</span>
                </div>
            </div>
            <div class="resumo-card">
                <div class="resumo-icon">👩‍⚕️</div>
                <div class="resumo-info">
                    <span id="total-terapeutas" class="resumo-numero">--</span>
                    <span class="resumo-label">Terapeutas</span>
                </div>
            </div>
            <div class="resumo-card">
                <div class="resumo-icon">📅</div>
                <div class="resumo-info">
                    <span id="total-sessoes" class="resumo-numero">--</span>
                    <span class="resumo-label">Sessões Hoje</span>
                </div>
            </div>
            <div class="resumo-card alerta">
                <div class="resumo-icon">⚠️</div>
                <div class="resumo-info">
                    <span id="total-aguardando" class="resumo-numero">--</span>
                    <span class="resumo-label">Aguardando Agendamento</span>
                </div>
            </div>
        </section>

        <!-- GRID PRINCIPAL -->
        <div class="grid-principal">

            <!-- EDITOR DE AGENDA -->
            <section class="card-secao">
                <div class="secao-header">
                    <h2>📆 Editor de Agendas Semanais</h2>
                    <select id="select-terapeuta" class="select-terapeuta" aria-label="Selecionar terapeuta">
                        <option value="">Selecione um terapeuta...</option>
                    </select>
                </div>
                <div class="agenda-grid" id="agenda-grid">
                    <p class="carregando">Selecione um terapeuta para ver a agenda.</p>
                </div>
                <div class="agenda-footer">
                    <div class="legenda">
                        <span class="legenda-item sessao-individual">Sessão Individual</span>
                        <span class="legenda-item avaliacao">Avaliação</span>
                        <span class="legenda-item terapia-fala">Terapia de Fala</span>
                    </div>
                    <button class="btn-salvar" onclick="salvarAgenda()">Salvar Alterações</button>
                </div>
            </section>

            <!-- OCUPAÇÃO DOS TERAPEUTAS -->
            <section class="card-secao">
                <div class="secao-header">
                    <h2>📊 Ocupação dos Terapeutas</h2>
                </div>
                <div id="ocupacao-lista" class="ocupacao-lista">
                    <p class="carregando">Carregando dados...</p>
                </div>

                <!-- PACIENTES AGUARDANDO -->
                <div class="secao-header" style="margin-top: 24px;">
                    <h2>⏳ Pacientes Aguardando</h2>
                </div>
                <div id="aguardando-lista" class="aguardando-lista">
                    <p class="carregando">Carregando dados...</p>
                </div>
            </section>

        </div>

    </main>

    <script src="/js/acessibilidade.js"></script>
    <script src="/js/painel-admin.js"></script>

</body>
</html>