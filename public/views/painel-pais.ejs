<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TEAdm - Painel da Família</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/painel-pais.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="overlay" id="overlay"></div>

    <!-- BARRA DE ACESSIBILIDADE -->
    <div class="barra-acessibilidade" role="toolbar" aria-label="Ferramentas de acessibilidade">
        <span>Acessibilidade:</span>
        <button class="btn-acess" onclick="diminuirFonte()" aria-label="Diminuir fonte">A-</button>
        <button class="btn-acess" onclick="aumentarFonte()" aria-label="Aumentar fonte">A+</button>
        <button class="btn-acess" id="btn-contraste" onclick="alternarContraste()" aria-label="Alternar alto contraste">◑ Contraste</button>
        <button class="btn-acess" id="btn-voz" onclick="alternarVoz()" aria-label="Ativar leitura de tela">🔊 Leitura de tela</button>
        <button class="btn-acess" onclick="abrirLibras()" aria-label="Abrir intérprete de Libras">🤟 Libras</button>
    </div>

    <!-- HEADER -->
    <header class="header">
        <div class="menu_btn" id="menu_btn">
            <i class="bi bi-list"></i>
        </div>
        
        <div class="sidebar" id="sidebar">
            <div class="closeBtn" id="closeBtn">
                <i class="bi bi-x"></i>
            </div>
            <nav>
                <ul>
                    <li><a href="/">Inicio</a></i>
                    <li><a href="/painel_pais">Painel</a></i>
                    <li><a href="/calendario">Calendario</a></i>
                    <li><a href="#">Dados</a></i>
                </ul>
            </nav>
        </div>
        
        <div class="header-logo">
            <h1><span class="te">TE</span><span class="adm">Adm</span></h1>
        </div>
        <div class="header-info">
            <span>👤 Olá, <span id="nome-usuario"><i class="bi bi-list"></i>...</span></span>
            <a href="/login" class="btn-sair">Sair</a>
        </div>
    </header>

    <main class="painel-container">
        
        

        <div class="boas-vindas">
            <h2>🎉 Bem-vindo(a), <span id="nome-boas-vindas">...</span>!</h2>
            <p>Acompanhe abaixo o desenvolvimento do seu filho(a)</p>
        </div>

        <section class="cards-grid">
            <div class="card" onclick="window.location.href='/calendario'">
                <div class="card-icon">📅</div>
                <h3>Calendário</h3>
                <p>Dias de Terapia & Horários</p>
            </div>
            <div class="card">
                <div class="card-icon">📊</div>
                <h3>Estatísticas</h3>
                <p>Taxa de Presença & Faltas</p>
            </div>
            <div class="card">
                <div class="card-icon">👩‍⚕️</div>
                <h3>Terapeutas</h3>
                <p>Terapeutas & Disponíveis</p>
            </div>
            <div class="card">
                <div class="card-icon">🗓️</div>
                <h3>Data</h3>
                <p>Próxima Data de Devolutiva</p>
            </div>
            <div class="card">
                <div class="card-icon">📄</div>
                <h3>Documento</h3>
                <p>Acesso às Últimas Avaliações</p>
            </div>
        </section>

        <section class="frequencia-section">
            <h2>Taxa de Comparecimento</h2>
            <div id="frequencia-lista" class="frequencia-cards">
                <p class="carregando">Carregando dados...</p>
            </div>
        </section>

    </main>

    <script src="/js/acessibilidade.js"></script>
    <script src="/js/painel-pais.js"></script>

</body>
</html>