<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TEAdm - Painel da Família</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/painel-pais.css">
</head>
<body>

    <!-- HEADER -->
    <header class="header">
        <div class="header-logo">
            <h1><span class="te">TE</span><span class="adm">Adm</span></h1>
        </div>
        <div class="header-info">
            <span>👤 Olá, <span id="nome-usuario">...</span></span>
            <a href="/pages/login.html" class="btn-sair">Sair</a>
        </div>
    </header>

    <!-- PAINEL PRINCIPAL -->
    <main class="painel-container">

        <!-- BOAS VINDAS -->
        <div class="boas-vindas">
            <h2>🎉 Bem-vindo(a), <span id="nome-boas-vindas">...</span>!</h2>
            <p>Acompanhe abaixo o desenvolvimento do seu filho(a)</p>
        </div>

        <!-- CARDS DE ACESSO RÁPIDO -->
        <section class="cards-grid">

            <div class="card" onclick="window.location.href='/pages/calendario.html'">
                <div class="card-icon">📅</div>
                <h3>Calendário</h3>
                <p>Dias de Terapia & Horários</p>
            </div>

            <div class="card">
                <div class="card-icon">📊</div>
                <h3>Estatísticas</h3>
                <p>Taxa de Presença & Faltas</p>
            </div>

            <div class="card">
                <div class="card-icon">👩‍⚕️</div>
                <h3>Terapeutas</h3>
                <p>Terapeutas & Disponíveis</p>
            </div>

            <div class="card">
                <div class="card-icon">🗓️</div>
                <h3>Data</h3>
                <p>Próxima Data de Devolutiva</p>
            </div>

            <div class="card">
                <div class="card-icon">📄</div>
                <h3>Documento</h3>
                <p>Acesso às Últimas Avaliações</p>
            </div>

        </section>

        <!-- FREQUÊNCIA -->
        <section class="frequencia-section">
            <h2>Taxa de Comparecimento</h2>
            <div id="frequencia-lista" class="frequencia-cards">
                <!-- Preenchido dinamicamente pelo JS -->
                <p class="carregando">Carregando dados...</p>
            </div>
        </section>

    </main>

    <script src="/js/painel-pais.js"></script>

</body>
</html>