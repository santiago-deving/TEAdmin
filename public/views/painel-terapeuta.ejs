<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TEAdm - Painel do Terapeuta</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/painel-terapeuta.css">
</head>
<body>

    <!-- BARRA DE ACESSIBILIDADE -->
    <div class="barra-acessibilidade" role="toolbar" aria-label="Ferramentas de acessibilidade">
        <span>Acessibilidade:</span>
        <button class="btn-acess" onclick="diminuirFonte()" aria-label="Diminuir fonte">A-</button>
        <button class="btn-acess" onclick="aumentarFonte()" aria-label="Aumentar fonte">A+</button>
        <button class="btn-acess" id="btn-contraste" onclick="alternarContraste()" aria-label="Alternar alto contraste">◑ Contraste</button>
        <button class="btn-acess" id="btn-voz" onclick="alternarVoz()" aria-label="Ativar leitura de tela">🔊 Leitura de tela</button>
        <button class="btn-acess" onclick="abrirLibras()" aria-label="Abrir intérprete de Libras">🤟 Libras</button>
    </div>

    <!-- HEADER -->
    <header class="header">
        <div class="header-logo">
            <h1><span class="te">TE</span><span class="adm">Adm</span></h1>
        </div>
        <div class="header-info">
            <span class="status-online">● Online</span>
            <span>👤 Dr(a). <span id="nome-terapeuta">...</span></span>
            <a href="/pages/login.html" class="btn-sair">Sair</a>
        </div>
    </header>

    <main class="painel-container">

        <div class="boas-vindas">
            <h2>👩‍⚕️ Bem-vindo(a), Dr(a). <span id="nome-boas-vindas">...</span>!</h2>
            <p>Gerencie seus pacientes e agenda pelo painel abaixo</p>
        </div>

        <div class="grid-principal">
            <section class="card-secao">
                <div class="secao-header">
                    <h2>📋 Acompanhamento de Frequência</h2>
                    <span class="subtitulo-secao">Monitoramento de Pacientes</span>
                </div>
                <table class="tabela-frequencia">
                    <thead>
                        <tr>
                            <th>Paciente</th>
                            <th>Frequência (%)</th>
                            <th>Última Presença</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="tabela-pacientes">
                        <tr><td colspan="4" class="carregando">Carregando pacientes...</td></tr>
                    </tbody>
                </table>
            </section>

            <section class="card-secao">
                <div class="secao-header">
                    <h2>🗓️ Próximos Horários</h2>
                </div>
                <div id="horarios-lista" class="horarios-lista">
                    <p class="carregando">Carregando horários...</p>
                </div>
            </section>
        </div>

        <section class="card-secao">
            <div class="secao-header">
                <h2>👨‍👩‍👧 Pacientes Atuais</h2>
            </div>
            <div id="pacientes-grid" class="pacientes-grid">
                <p class="carregando">Carregando pacientes...</p>
            </div>
        </section>

    </main>

    <script src="/js/acessibilidade.js"></script>
    <script src="/js/painel-terapeuta.js"></script>

</body>
</html>